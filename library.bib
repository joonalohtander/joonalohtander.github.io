	file = {psm_machine_learning.pdf:Z\:\\projects\\resilience-and-rtc\\literature\\psm_machine_learning.pdf:application/pdf},
}

@article{mendolia_effect_2014,
	title = {The effect of personality traits on subject choice and performance in high school: {Evidence} from an {English} cohort},
