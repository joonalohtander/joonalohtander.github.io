	author = {Chen, Yan and Li, Sherry Xin},
	month = mar,
	year = {2009},
	keywords = {Economic Sociology, and Cognitive Factors on Decision Making, Design of Experiments: Laboratory, Economic Anthropology, Emotional, Individual, Micro-Based Behavioral Economics: Role and Effects of Psychological, Social},
	pages = {431--457},
}

@article{karlan_using_2005,
	title = {Using {Experimental} {Economics} to {Measure} {Social} {Capital} and {Predict} {Financial} {Decisions}},
	volume = {95},
	copyright = {Copyright American Economic Association Dec 2005},
	issn = {00028282},
	url = {https://www.proquest.com/docview/233028628/abstract/9A7418D788274365PQ/1},
	abstract = {Questions remain as to whether results from experimental economics are generalizable to real decisions in nonlaboratory settings. Furthermore, questions persist about whether social capital helps mitigate information asymmetries in credit markets. I examine whether behavior in two laboratory games, Trust and a Public Goods, predicts loan repayments to a Peruvian group-lending microfinance program. Since this program relies on social capital to enforce repayment, this tests the external validity of the games. Individuals identified as "trustworthy" by the Trust Game are indeed less likely to default on their loans. No similar support is found for the game's identification of "trusting" individuals. [PUBLICATION ABSTRACT]},
	language = {English},
	number = {5},
	urldate = {2025-02-05},
