	pages = {69--110},
	file = {Vegetabile et al. - 2021 - Nonparametric estimation of population average dos.pdf:/home/joona/Zotero/storage/D9F2DHAW/Vegetabile et al. - 2021 - Nonparametric estimation of population average dos.pdf:application/pdf},
